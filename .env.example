# LLM 提供商配置

# 提供商优先级列表（多故障转移）：按顺序尝试各提供商，失败时自动切换
# 示例: LLM_PROVIDERS=zhipu,deepseek
LLM_PROVIDERS=zhipu,deepseek

# 指定模型名（可选，不填则使用各提供商的默认模型）
LLM_MODEL=

# 智谱 AI
# 文档: https://docs.bigmodel.cn/cn/guide/start/model-overview
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_DEFAULT_MODEL=glm-4.7-flash

# DeepSeek
# 文档: https://api-docs.deepseek.com/zh-cn/
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

QUIZ_DEFAULT_COUNT=10
QUIZ_MAX_COUNT=30
